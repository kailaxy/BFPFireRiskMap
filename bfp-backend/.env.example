# Supabase Postgres configuration
PORT=5000
NODE_ENV=production
DATA_PROVIDER=postgres

# Direct Postgres connection
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@YOUR_SUPABASE_HOST:5432/postgres?sslmode=require

# Optional split variables (kept in sync)
DB_HOST=YOUR_SUPABASE_HOST.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD
DB_SSL=true

# Supabase project reference
SUPABASE_PROJECT_REF=YOUR_SUPABASE_PROJECT_REF
SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY

# Application secrets - GENERATE NEW VALUES FOR PRODUCTION
JWT_SECRET=your-secret-key-here-change-in-production
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Forecast API configuration
FORECAST_SERVICE_URL=http://localhost:8001

# Firebase configuration (optional, if DATA_PROVIDER=firestore)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-key-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
